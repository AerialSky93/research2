//@version=5
strategy("Daily + 5 Minute Up Trend Strategy", overlay=true, process_orders_on_close=true)

dailyTf = input.timeframe("D", "Higher Time Frame")
lowerTf = input.timeframe("5", "Lower Time Frame")
dailyTrendBars = 1
lowerTrendBars = 2
showBackground = input.bool(true, "Highlight When Both Are Up")
swingLeftBars = input.int(2, "Swing Left Bars", minval=1)
swingRightBars = input.int(2, "Swing Right Bars", minval=1)
swingProximityPercent = input.float(0.2, "Near Swing %", minval=0.01, step=0.05)

dailyOpen = request.security(syminfo.tickerid, dailyTf, open)
previousDailyClose = request.security(syminfo.tickerid, dailyTf, close[1])
lowerClose = request.security(syminfo.tickerid, lowerTf, close)
isLowerTfChart = timeframe.period == lowerTf

// Treat the daily trend as "today is trading above yesterday's close"
// so it can update intraday on a 5 minute chart.
dailyUp = close > previousDailyClose and close > dailyOpen
lowerUp = ta.rising(lowerClose, lowerTrendBars)
swingHigh = ta.pivothigh(high, swingLeftBars, swingRightBars)
swingLow = ta.pivotlow(low, swingLeftBars, swingRightBars)

var float previousSwingHigh = na
var float previousSwingLow = na

if not na(swingHigh)
    previousSwingHigh := swingHigh

if not na(swingLow)
    previousSwingLow := swingLow

highBuffer = not na(previousSwingHigh) ? previousSwingHigh * swingProximityPercent / 100.0 : na
lowBuffer = not na(previousSwingLow) ? previousSwingLow * swingProximityPercent / 100.0 : na
nearPreviousSwingHigh = not na(previousSwingHigh) and high >= previousSwingHigh - highBuffer and low <= previousSwingHigh + highBuffer
nearPreviousSwingLow = not na(previousSwingLow) and high >= previousSwingLow - lowBuffer and low <= previousSwingLow + lowBuffer
downClosedCandle = close < open
bothUp = isLowerTfChart and dailyUp and lowerUp
enterLong = bothUp and downClosedCandle and (nearPreviousSwingHigh or nearPreviousSwingLow)
exitLong = strategy.position_size > 0 and not bothUp

if enterLong and strategy.position_size == 0
    strategy.entry("Long", strategy.long)

if exitLong
    strategy.close("Long")

bgcolor(showBackground and bothUp ? color.new(color.green, 85) : na, title="Both Time Frames Up")

plotshape(dailyUp, title="Daily Up", style=shape.circle, location=location.top, color=color.blue, size=size.tiny, text="D")
plotshape(lowerUp, title="5 Minute Up", style=shape.circle, location=location.top, color=color.orange, size=size.tiny, text="5")
plotshape(bothUp, title="Both Up", style=shape.triangleup, location=location.belowbar, color=color.lime, size=size.small, text="UP")
plotshape(enterLong, title="Long Entry", style=shape.labelup, location=location.belowbar, color=color.green, size=size.small, text="BUY")
plotshape(exitLong, title="Long Exit", style=shape.labeldown, location=location.abovebar, color=color.red, size=size.small, text="EXIT")
plotshape(swingHigh, title="Swing High", style=shape.triangledown, location=location.absolute, color=color.red, size=size.small, offset=-swingRightBars, text="SH")
plotshape(swingLow, title="Swing Low", style=shape.triangleup, location=location.absolute, color=color.aqua, size=size.small, offset=-swingRightBars, text="SL")
plotshape(nearPreviousSwingHigh, title="Near Previous Swing High", style=shape.square, location=location.abovebar, color=color.maroon, size=size.tiny, text="PH")
plotshape(nearPreviousSwingLow, title="Near Previous Swing Low", style=shape.square, location=location.belowbar, color=color.navy, size=size.tiny, text="PL")
