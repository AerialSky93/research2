//@version=5
strategy('Swing pivots Wick Data Testing', 'SwingPivotsWickDataTesting', overlay = true,
     initial_capital = 100000, default_qty_type = strategy.fixed, default_qty_value = 10,
     commission_type = strategy.commission.percent, commission_value = 0.0, pyramiding = 10,
     process_orders_on_close = false, max_lines_count = 500, max_labels_count = 500)

drawLinesFrom = input.time(timestamp('9 Dec 2025 00:00 +0000'), 'Draw lines from',
     tooltip = 'Only pivots confirmed on or after this date will create horizontal lines.')
swingHistoryHours = input.float(24.0, 'Swing history (hours)', minval = 0.25, step = 0.25,
     tooltip = 'How long swing pivots stay in memory for SFP (hours converted to bars).')
swingPlotHours = input.float(24.0, 'Swing plot length (hours)', minval = 0.25, step = 0.25,
     tooltip = 'How long confirmed swing-high and swing-low plots remain visible.')
swingPlotWidth = input.int(2, 'Swing plot width', minval = 1, maxval = 5)
enableBullishSfp = input.bool(true, 'Enable Bullish SFP')
enableBearishSfp = input.bool(true, 'Enable Bearish SFP')
enableSfpStopLoss = input.bool(false, 'Enable SFP stop loss',
     tooltip = 'Places a stop at the swing level that invalidates each SFP trade.')
maxHoldHours = input.float(3.0, 'Max hold time (hours)', minval = 0.25, step = 0.25,
     tooltip = 'Closes any open position after this many hours from entry.')
enableEodFlatten = input.bool(false, 'Enable 3:00 PM ET closeout',
     tooltip = 'When enabled, closes open positions during the 3:00 PM ET hour and blocks new entries in that window.')

historicalWindowDays = input.int(7, 'Historical window (days)', minval = 1, maxval = 365,
     tooltip = 'How many calendar days after "Draw lines from" are allowed for horizontal line creation.')
enableDebugLogs = input.bool(true, 'Enable debug logs',
     tooltip = 'Logs SFP detection, entry gating, and the bar immediately after an SFP.')
tfSec = math.max(timeframe.in_seconds(), 1)
swingWindowBars = math.max(1, int(math.round(swingHistoryHours * 3600.0 / tfSec)))
msToExtend = int(swingPlotHours * 60.0 * 60.0 * 1000.0)
maxHoldMs = int(maxHoldHours * 60.0 * 60.0 * 1000.0)
drawLinesUntil = drawLinesFrom + historicalWindowDays * 24 * 60 * 60 * 1000

var array<float> swingHighPrices = array.new_float()
var array<int> swingHighBars = array.new_int()
var array<float> swingLowPrices = array.new_float()
var array<int> swingLowBars = array.new_int()
visibleSwingHighs = input.int(250, 'Max swing high lines', minval = 1, maxval = 250,
     tooltip = 'Swing-high line segments drawn from selected start date.')
visibleSwingLows = input.int(250, 'Max swing low lines', minval = 1, maxval = 250,
     tooltip = 'Swing-low line segments drawn from selected start date.')
var array<line> swingHighLines = array.new_line()
var array<line> swingLowLines = array.new_line()

currentSwingLow = barstate.isconfirmed and low[1] < low[0] and low[1] < low[2]
currentSwingHigh = barstate.isconfirmed and high[1] > high[0] and high[1] > high[2]

// SFP memory only: drop old pivots by bar window.
// swingHighBars[i] = confirmation bar index; pivot bar = that minus 1.
while array.size(swingHighBars) > 0
    pivotBarHi = array.get(swingHighBars, 0) - 1
    if bar_index - pivotBarHi < swingWindowBars
        break
    array.shift(swingHighPrices)
    array.shift(swingHighBars)
while array.size(swingLowBars) > 0
    pivotBarLo = array.get(swingLowBars, 0) - 1
    if bar_index - pivotBarLo < swingWindowBars
        break
    array.shift(swingLowPrices)
    array.shift(swingLowBars)

if currentSwingHigh
    pSh = high[1]
    pivotTime = time[1]
    highLineEnd = pivotTime + msToExtend
    array.push(swingHighPrices, pSh)
    array.push(swingHighBars, bar_index)
    if pivotTime >= drawLinesFrom and pivotTime < drawLinesUntil
        array.push(swingHighLines, line.new(pivotTime, pSh, highLineEnd, pSh, xloc = xloc.bar_time, extend = extend.none, color = color.new(#E78F97, 0), width = swingPlotWidth))
        if array.size(swingHighLines) > visibleSwingHighs
            line.delete(array.shift(swingHighLines))
if currentSwingLow
    pSl = low[1]
    pivotTime = time[1]
    lowLineEnd = pivotTime + msToExtend
    array.push(swingLowPrices, pSl)
    array.push(swingLowBars, bar_index)
    if pivotTime >= drawLinesFrom and pivotTime < drawLinesUntil
        array.push(swingLowLines, line.new(pivotTime, pSl, lowLineEnd, pSl, xloc = xloc.bar_time, extend = extend.none, color = color.new(#73C8BA, 0), width = swingPlotWidth))
        if array.size(swingLowLines) > visibleSwingLows
            line.delete(array.shift(swingLowLines))

plotshape(currentSwingLow, title = 'Swing low', style = shape.triangleup, location = location.belowbar, offset = -1, size = size.tiny, color = color.teal, text = '\nSL')
plot(currentSwingLow ? low[1] : na, 'Swing low level', color = color.new(color.teal, 0), style = plot.style_circles, offset = -1, linewidth = 2)
plotshape(currentSwingHigh, title = 'Swing high', style = shape.triangledown, location = location.abovebar, offset = -1, size = size.tiny, color = color.orange, text = 'SH\n')
plot(currentSwingHigh ? high[1] : na, 'Swing high level', color = color.new(color.orange, 0), style = plot.style_circles, offset = -1, linewidth = 2)

// Bearish SFP vs any stored swing high in window: wick above that high, close back below (only after pivot bar).
var bool bearSweepAny = false
var float bearSweepLevel = na
bearSweepAny := false
bearSweepLevel := na
if barstate.isconfirmed
    nHigh = array.size(swingHighPrices)
    if nHigh > 0
        for i = 0 to nHigh - 1
            sh = array.get(swingHighPrices, i)
            shBar = array.get(swingHighBars, i)
            isBearSweep = bar_index > shBar and high > sh and close < sh
            bearSweepAny := bearSweepAny or isBearSweep
            if isBearSweep
                bearSweepLevel := sh
bearRaw = bearSweepAny

// Bullish SFP vs any stored swing low in window.
var bool bullSweepAny = false
var float bullSweepLevel = na
bullSweepAny := false
bullSweepLevel := na
if barstate.isconfirmed
    nLow = array.size(swingLowPrices)
    if nLow > 0
        for i = 0 to nLow - 1
            sl = array.get(swingLowPrices, i)
            slBar = array.get(swingLowBars, i)
            isBullSweep = bar_index > slBar and low < sl and close > sl
            bullSweepAny := bullSweepAny or isBullSweep
            if isBullSweep
                bullSweepLevel := sl
bullRaw = bullSweepAny

// first time in cycle
bearSfp = enableBearishSfp and bearRaw and (na(bearRaw[1]) or not bearRaw[1])
bullSfp = enableBullishSfp and bullRaw and (na(bullRaw[1]) or not bullRaw[1])
bullSfpPrevBar = bar_index > 0 and bullSfp[1]
bearSfpPrevBar = bar_index > 0 and bearSfp[1]

plotshape(bearSfp, title = 'Bearish SFP', style = shape.xcross, location = location.abovebar, size = size.tiny, color = color.new(color.red, 0), text = '\nSFP')
plotshape(bullSfp, title = 'Bullish SFP', style = shape.xcross, location = location.belowbar, size = size.tiny, color = color.new(color.lime, 0), text = 'SFP\n')

timezoneEt = 'America/New_York'
formatTimeEt(ts) =>
    hh = hour(ts, timezoneEt)
    mm = minute(ts, timezoneEt)
    hhText = hh < 10 ? '0' + str.tostring(hh) : str.tostring(hh)
    mmText = mm < 10 ? '0' + str.tostring(mm) : str.tostring(mm)
    hhText + ':' + mmText

nyMinutes = hour(time, timezoneEt) * 60 + minute(time, timezoneEt)
inEodFlattenWindow = nyMinutes >= 15 * 60 and nyMinutes < 16 * 60
dayKeyEt = year(time, timezoneEt) * 10000 + month(time, timezoneEt) * 100 + dayofmonth(time, timezoneEt)
barDateTimeEt = str.tostring(year(time, timezoneEt)) + '-' + str.tostring(month(time, timezoneEt)) + '-' + str.tostring(dayofmonth(time, timezoneEt)) + ' ' + str.tostring(hour(time, timezoneEt)) + ':' + str.tostring(minute(time, timezoneEt))
logPrefix = 'barDateTimeEt=' + barDateTimeEt + ' '
inDrawWindow = time >= drawLinesFrom and time < drawLinesUntil

var int eodFlattenedDayKey = na
var int positionEntryTime = na

positionOpened = strategy.position_size != 0 and strategy.position_size[1] == 0
positionReversed = strategy.position_size > 0 and strategy.position_size[1] < 0 or strategy.position_size < 0 and strategy.position_size[1] > 0
positionAdded = math.abs(strategy.position_size) > math.abs(strategy.position_size[1]) and strategy.position_size * strategy.position_size[1] > 0

if positionOpened or positionReversed or positionAdded
    positionEntryTime := time
else if strategy.position_size == 0
    positionEntryTime := na

timedExitDue = strategy.position_size != 0 and not na(positionEntryTime) and time - positionEntryTime >= maxHoldMs
eodExitDue = enableEodFlatten and inEodFlattenWindow and strategy.position_size != 0 and (na(eodFlattenedDayKey) or eodFlattenedDayKey != dayKeyEt)

// Entries: reverse on opposite SFP (single `strategy.entry` id, pyramiding = 0). Only during regular session (`session.ismarket`).
canEnterSfpEt = session.ismarket and (not enableEodFlatten or not inEodFlattenWindow)
submitBullEntry = inDrawWindow and bullSfp and canEnterSfpEt
submitBearEntry = inDrawWindow and bearSfp and canEnterSfpEt
bullEntryBar = bar_index > 0 and inDrawWindow and inDrawWindow[1] and bullSfp[1] and canEnterSfpEt[1]
bearEntryBar = bar_index > 0 and inDrawWindow and inDrawWindow[1] and bearSfp[1] and canEnterSfpEt[1]
timedExitDeferredForEntry = timedExitDue and (submitBullEntry or submitBearEntry)
timedExitNow = timedExitDue and not timedExitDeferredForEntry
actualLongEntryBar = (positionOpened or positionReversed or positionAdded) and strategy.position_size > 0
actualShortEntryBar = (positionOpened or positionReversed or positionAdded) and strategy.position_size < 0
nextBullEntryNumber = strategy.position_size > 0 ? strategy.opentrades + 1 : 1
nextBearEntryNumber = strategy.position_size < 0 ? strategy.opentrades + 1 : 1
nextBullEntryId = 'SFP Long ' + str.tostring(nextBullEntryNumber)
nextBearEntryId = 'SFP Short ' + str.tostring(nextBearEntryNumber)

if inDrawWindow
    log.info(logPrefix + 'bar_index=' + str.tostring(bar_index))
    log.info(logPrefix + 'bullSfp=' + str.tostring(bullSfp))
    log.info(logPrefix + 'bearSfp=' + str.tostring(bearSfp))
    log.info(logPrefix + 'bullSweepLevel=' + str.tostring(bullSweepLevel))
    log.info(logPrefix + 'bearSweepLevel=' + str.tostring(bearSweepLevel))
    log.info(logPrefix + 'bullSfpPrevBar=' + str.tostring(bullSfpPrevBar))
    log.info(logPrefix + 'bearSfpPrevBar=' + str.tostring(bearSfpPrevBar))
    log.info(logPrefix + 'canEnterSfpEt=' + str.tostring(canEnterSfpEt))
    log.info(logPrefix + 'session.ismarket=' + str.tostring(session.ismarket))
    log.info(logPrefix + 'enableEodFlatten=' + str.tostring(enableEodFlatten))
    log.info(logPrefix + 'inEodFlattenWindow=' + str.tostring(inEodFlattenWindow))
    log.info(logPrefix + 'strategy.position_size=' + str.tostring(strategy.position_size))
    log.info(logPrefix + 'submitBullEntry=' + str.tostring(submitBullEntry))
    log.info(logPrefix + 'submitBearEntry=' + str.tostring(submitBearEntry))
    log.info(logPrefix + 'bullEntryBar=' + str.tostring(bullEntryBar))
    log.info(logPrefix + 'bearEntryBar=' + str.tostring(bearEntryBar))
    log.info(logPrefix + 'positionAdded=' + str.tostring(positionAdded))
    log.info(logPrefix + 'timedExitDue=' + str.tostring(timedExitDue))
    log.info(logPrefix + 'timedExitDeferredForEntry=' + str.tostring(timedExitDeferredForEntry))
    log.info(logPrefix + 'timedExitNow=' + str.tostring(timedExitNow))
    log.info(logPrefix + 'actualLongEntryBar=' + str.tostring(actualLongEntryBar))
    log.info(logPrefix + 'actualShortEntryBar=' + str.tostring(actualShortEntryBar))
    log.info(logPrefix + 'process_orders_on_close=false')

if actualLongEntryBar
    label.new(bar_index, low, 'BUY\n' + formatTimeEt(time), xloc = xloc.bar_index, yloc = yloc.belowbar, style = label.style_label_up, color = color.new(color.lime, 0), textcolor = color.white, size = size.tiny)

if actualShortEntryBar
    label.new(bar_index, high, 'SELL\n' + formatTimeEt(time), xloc = xloc.bar_index, yloc = yloc.abovebar, style = label.style_label_down, color = color.new(color.red, 0), textcolor = color.white, size = size.tiny)

if timedExitNow or eodExitDue
    label.new(bar_index, high, 'EXIT\n' + formatTimeEt(time), xloc = xloc.bar_index, yloc = yloc.abovebar, style = label.style_label_down, color = color.new(color.yellow, 0), textcolor = color.black, size = size.tiny)
if submitBullEntry
    strategy.entry(nextBullEntryId, strategy.long, comment = 'Bull SFP Trade')
    if enableSfpStopLoss
        strategy.exit('Stop ' + nextBullEntryId, from_entry = nextBullEntryId, stop = bullSweepLevel, comment = 'Bull SFP stop')
else if submitBearEntry
    strategy.entry(nextBearEntryId, strategy.short, comment = 'Bear SFP Trade')
    if enableSfpStopLoss
        strategy.exit('Stop ' + nextBearEntryId, from_entry = nextBearEntryId, stop = bearSweepLevel, comment = 'Bear SFP stop')

if timedExitNow
    strategy.close_all(comment = 'Timed exit after 3 hours')

if eodExitDue
    strategy.close_all(comment = 'Flatten 3:00 PM ET')
    eodFlattenedDayKey := dayKeyEt
