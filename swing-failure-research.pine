//@version=5
strategy('Wick swing pivots (3-bar)', 'WickSwingPivots', overlay = true,
     initial_capital = 100000, default_qty_type = strategy.fixed, default_qty_value = 10,
     commission_type = strategy.commission.percent, commission_value = 0.1, pyramiding = 0,
     process_orders_on_close = true)

var float lastSwingHigh = na
var float lastSwingLow = na
var int lastSwingHighIndex = na
var int lastSwingLowIndex = na

// Swing low: middle candle’s low is below the lows of the bar before and the bar after (wick lows).
// Swing high: middle candle’s high is above the highs of the bar before and the bar after (wick highs).
// Confirmed on the close of the “following” bar so its wick is known.
swingLow = barstate.isconfirmed and low[1] < low[2] and low[1] < low[0]
swingHigh = barstate.isconfirmed and high[1] > high[2] and high[1] > high[0]

plotshape(swingLow, title = 'Swing low', style = shape.triangleup, location = location.belowbar, offset = -1, size = size.tiny, color = color.teal, text = 'SL')
plotshape(swingHigh, title = 'Swing high', style = shape.triangledown, location = location.abovebar, offset = -1, size = size.tiny, color = color.orange, text = 'SH')

plot(swingLow ? low[1] : na, 'Swing low level', color = color.new(color.teal, 0), style = plot.style_circles, offset = -1, linewidth = 2)
plot(swingHigh ? high[1] : na, 'Swing high level', color = color.new(color.orange, 0), style = plot.style_circles, offset = -1, linewidth = 2)

// Wick breaks prior swing high / low, then closes back inside. Sweep must be AFTER that swing level is committed
// (strictly later bar), and not on the same bar we print a new swing high / low.
bearRaw = barstate.isconfirmed and not na(lastSwingHigh) and (na(lastSwingHighIndex) or bar_index > lastSwingHighIndex) and not swingHigh and high > lastSwingHigh and close < lastSwingHigh
bullRaw = barstate.isconfirmed and not na(lastSwingLow) and (na(lastSwingLowIndex) or bar_index > lastSwingLowIndex) and not swingLow and low < lastSwingLow and close > lastSwingLow

// first time in cycle
bearSfp = bearRaw and (na(bearRaw[1]) or not bearRaw[1])
bullSfp = bullRaw and (na(bullRaw[1]) or not bullRaw[1])

if swingHigh
    lastSwingHigh := high[1]
    lastSwingHighIndex := bar_index
if swingLow
    lastSwingLow := low[1]
    lastSwingLowIndex := bar_index

if bearSfp
    label.new(bar_index, high, 'SFP bear\n(sweep ▲ fail)', style = label.style_label_down, color = color.new(color.red, 20), textcolor = color.white, size = size.small)
if bullSfp
    label.new(bar_index, low, 'SFP bull\n(sweep ▼ fail)', style = label.style_label_up, color = color.new(color.green, 20), textcolor = color.white, size = size.small)

plotshape(bearSfp, title = 'Bearish SFP', style = shape.xcross, location = location.abovebar, size = size.tiny, color = color.new(color.red, 0), text = 'Sf')
plotshape(bullSfp, title = 'Bullish SFP', style = shape.xcross, location = location.belowbar, size = size.tiny, color = color.new(color.lime, 0), text = 'Sf')

// Entries: reverse on opposite SFP (single `strategy.entry` id, pyramiding = 0).
if bullSfp
    strategy.entry('SFP', strategy.long, comment = 'Bull SFP')
else if bearSfp
    strategy.entry('SFP', strategy.short, comment = 'Bear SFP')
