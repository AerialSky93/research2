//@version=5
strategy('Swing pivots Wick (3-bar)', 'SwingPivotsWick', overlay = true,
     initial_capital = 100000, default_qty_type = strategy.fixed, default_qty_value = 10,
     commission_type = strategy.commission.percent, commission_value = 0.1, pyramiding = 0,
     process_orders_on_close = true)

var float lastSwingHigh = na
var float lastSwingLow = na
var int lastSwingHighIndex = na
var int lastSwingLowIndex = na

swingLow = barstate.isconfirmed and low[1] < low[0] and low[1] < low[2]
swingHigh = barstate.isconfirmed and high[1] > high[0] and high[1] > high[2]

plotshape(swingLow, title = 'Swing low', style = shape.triangleup, location = location.belowbar, offset = -1, size = size.tiny, color = color.teal, text = 'SL')
plot(swingLow ? low[1] : na, 'Swing low level', color = color.new(color.teal, 0), style = plot.style_circles, offset = -1, linewidth = 2)
plotshape(swingHigh, title = 'Swing high', style = shape.triangledown, location = location.abovebar, offset = -1, size = size.tiny, color = color.orange, text = 'SH')
plot(swingHigh ? high[1] : na, 'Swing high level', color = color.new(color.orange, 0), style = plot.style_circles, offset = -1, linewidth = 2)

bearRaw = (
    barstate.isconfirmed
    and not swingHigh
    and not na(lastSwingHigh)
    and (na(lastSwingHighIndex) or bar_index > lastSwingHighIndex)
    and high > lastSwingHigh
    and close < lastSwingHigh
)
bullRaw = (
    barstate.isconfirmed
    and not swingLow
    and not na(lastSwingLow)
    and (na(lastSwingLowIndex) or bar_index > lastSwingLowIndex)
    and low < lastSwingLow
    and close > lastSwingLow
)

// first time in cycle
bearSfp = bearRaw and (na(bearRaw[1]) or not bearRaw[1])
bullSfp = bullRaw and (na(bullRaw[1]) or not bullRaw[1])

if swingHigh
    lastSwingHigh := high[1]
    lastSwingHighIndex := bar_index
    lastSwingLow := na
    lastSwingLowIndex := na
if swingLow
    lastSwingLow := low[1]
    lastSwingLowIndex := bar_index
    lastSwingHigh := na
    lastSwingHighIndex := na

plotshape(bearSfp, title = 'Bearish SFP', style = shape.xcross, location = location.abovebar, size = size.tiny, color = color.new(color.red, 0), text = 'SFP')
plotshape(bullSfp, title = 'Bullish SFP', style = shape.xcross, location = location.belowbar, size = size.tiny, color = color.new(color.lime, 0), text = 'SFP')

timezoneEt = 'America/New_York'
nyMinutes = hour(time, timezoneEt) * 60 + minute(time, timezoneEt)
inEodFlattenWindow = nyMinutes >= 15 * 60 and nyMinutes < 16 * 60
// No new opening trades on or after 2:00 PM ET
before2pmEt = nyMinutes < 14 * 60
dayKeyEt = year(time, timezoneEt) * 10000 + month(time, timezoneEt) * 100 + dayofmonth(time, timezoneEt)

var int eodFlattenedDayKey = na

// Entries: reverse on opposite SFP (single `strategy.entry` id, pyramiding = 0). Only during regular session (`session.ismarket`); no new entries at/after 2:00 PM ET
canEnterSfpEt = session.ismarket and before2pmEt and not inEodFlattenWindow
if bullSfp and canEnterSfpEt
    strategy.entry('SFP', strategy.long, comment = 'Bull SFP Trade')
else if bearSfp and canEnterSfpEt
    strategy.entry('SFP', strategy.short, comment = 'Bear SFP Trade')

if inEodFlattenWindow and strategy.position_size != 0
    if na(eodFlattenedDayKey) or eodFlattenedDayKey != dayKeyEt
        strategy.close_all(comment = 'Flatten 3:00 PM ET')
        eodFlattenedDayKey := dayKeyEt
