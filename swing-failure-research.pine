//@version=5
strategy('Swing pivots Wick (3-bar)', 'SwingPivotsWick', overlay = true,
     initial_capital = 100000, default_qty_type = strategy.fixed, default_qty_value = 10,
     commission_type = strategy.commission.percent, commission_value = 0.1, pyramiding = 0,
     process_orders_on_close = true, max_lines_count = 500, max_labels_count = 500)

swingHistoryHours = input.float(24.0, 'Swing history (hours)', minval = 0.25, step = 0.25,
     tooltip = 'How long swing pivots stay in memory for SFP (hours converted to bars).')
swingPlotHours = input.float(24.0, 'Swing plot length (hours)', minval = 0.25, step = 0.25,
     tooltip = 'How long confirmed swing-high and swing-low plots remain visible.')
swingPlotWidth = input.int(2, 'Swing plot width', minval = 1, maxval = 5)
tfSec = math.max(timeframe.in_seconds(), 1)
swingWindowBars = math.max(1, int(math.round(swingHistoryHours * 3600.0 / tfSec)))
msToExtend = int(swingPlotHours * 60.0 * 60.0 * 1000.0)

var array<float> swingHighPrices = array.new_float()
var array<int> swingHighBars = array.new_int()
var array<float> swingLowPrices = array.new_float()
var array<int> swingLowBars = array.new_int()
visibleSwingHighs = input.int(5, 'Visible swing highs', minval = 1, maxval = 50,
     tooltip = 'Lux-style behavior: only keep a small set of current unbroken swing-high levels on the chart.')
visibleSwingLows = input.int(5, 'Visible swing lows', minval = 1, maxval = 50,
     tooltip = 'Lux-style behavior: only keep a small set of current unbroken swing-low levels on the chart.')
var array<line> swingHighLines = array.new_line()
var array<float> swingHighLinePrices = array.new_float()
var array<int> swingHighLineEnds = array.new_int()
var array<line> swingLowLines = array.new_line()
var array<float> swingLowLinePrices = array.new_float()
var array<int> swingLowLineEnds = array.new_int()

currentSwingLow = barstate.isconfirmed and low[1] < low[0] and low[1] < low[2]
currentSwingHigh = barstate.isconfirmed and high[1] > high[0] and high[1] > high[2]

// SFP memory only: drop old pivots by bar window.
// swingHighBars[i] = confirmation bar index; pivot bar = that minus 1.
while array.size(swingHighBars) > 0
    pivotBarHi = array.get(swingHighBars, 0) - 1
    if bar_index - pivotBarHi < swingWindowBars
        break
    array.shift(swingHighPrices)
    array.shift(swingHighBars)
while array.size(swingLowBars) > 0
    pivotBarLo = array.get(swingLowBars, 0) - 1
    if bar_index - pivotBarLo < swingWindowBars
        break
    array.shift(swingLowPrices)
    array.shift(swingLowBars)

highLineIndex = array.size(swingHighLines) - 1
while highLineIndex >= 0
    activeHighPrice = array.get(swingHighLinePrices, highLineIndex)
    activeHighEnd = array.get(swingHighLineEnds, highLineIndex)
    activeHighBroken = close > activeHighPrice
    activeHighExpired = time > activeHighEnd
    if activeHighBroken or activeHighExpired
        line.delete(array.get(swingHighLines, highLineIndex))
        array.remove(swingHighLines, highLineIndex)
        array.remove(swingHighLinePrices, highLineIndex)
        array.remove(swingHighLineEnds, highLineIndex)
    highLineIndex -= 1

lowLineIndex = array.size(swingLowLines) - 1
while lowLineIndex >= 0
    activeLowPrice = array.get(swingLowLinePrices, lowLineIndex)
    activeLowEnd = array.get(swingLowLineEnds, lowLineIndex)
    activeLowBroken = close < activeLowPrice
    activeLowExpired = time > activeLowEnd
    if activeLowBroken or activeLowExpired
        line.delete(array.get(swingLowLines, lowLineIndex))
        array.remove(swingLowLines, lowLineIndex)
        array.remove(swingLowLinePrices, lowLineIndex)
        array.remove(swingLowLineEnds, lowLineIndex)
    lowLineIndex -= 1

if currentSwingHigh
    pSh = high[1]
    highLineEnd = time[1] + msToExtend
    array.push(swingHighPrices, pSh)
    array.push(swingHighBars, bar_index)
    array.push(swingHighLines, line.new(time[1], pSh, time, pSh, xloc = xloc.bar_time, extend = extend.right, color = color.new(#E78F97, 0), width = swingPlotWidth))
    array.push(swingHighLinePrices, pSh)
    array.push(swingHighLineEnds, highLineEnd)
    if array.size(swingHighLines) > visibleSwingHighs
        line.delete(array.shift(swingHighLines))
        array.shift(swingHighLinePrices)
        array.shift(swingHighLineEnds)
if currentSwingLow
    pSl = low[1]
    lowLineEnd = time[1] + msToExtend
    array.push(swingLowPrices, pSl)
    array.push(swingLowBars, bar_index)
    array.push(swingLowLines, line.new(time[1], pSl, time, pSl, xloc = xloc.bar_time, extend = extend.right, color = color.new(#73C8BA, 0), width = swingPlotWidth))
    array.push(swingLowLinePrices, pSl)
    array.push(swingLowLineEnds, lowLineEnd)
    if array.size(swingLowLines) > visibleSwingLows
        line.delete(array.shift(swingLowLines))
        array.shift(swingLowLinePrices)
        array.shift(swingLowLineEnds)

plotshape(currentSwingLow, title = 'Swing low', style = shape.triangleup, location = location.belowbar, offset = -1, size = size.tiny, color = color.teal, text = '\nSL')
plot(currentSwingLow ? low[1] : na, 'Swing low level', color = color.new(color.teal, 0), style = plot.style_circles, offset = -1, linewidth = 2)
plotshape(currentSwingHigh, title = 'Swing high', style = shape.triangledown, location = location.abovebar, offset = -1, size = size.tiny, color = color.orange, text = 'SH\n')
plot(currentSwingHigh ? high[1] : na, 'Swing high level', color = color.new(color.orange, 0), style = plot.style_circles, offset = -1, linewidth = 2)

// Bearish SFP vs any stored swing high in window: wick above that high, close back below (only after pivot bar).
var bool bearSweepAny = false
bearSweepAny := false
if barstate.isconfirmed
    nHigh = array.size(swingHighPrices)
    if nHigh > 0
        for i = 0 to nHigh - 1
            sh = array.get(swingHighPrices, i)
            shBar = array.get(swingHighBars, i)
            bearSweepAny := bearSweepAny or (bar_index > shBar and high > sh and close < sh)
bearRaw = bearSweepAny

// Bullish SFP vs any stored swing low in window.
var bool bullSweepAny = false
bullSweepAny := false
if barstate.isconfirmed
    nLow = array.size(swingLowPrices)
    if nLow > 0
        for i = 0 to nLow - 1
            sl = array.get(swingLowPrices, i)
            slBar = array.get(swingLowBars, i)
            bullSweepAny := bullSweepAny or (bar_index > slBar and low < sl and close > sl)
bullRaw = bullSweepAny

// first time in cycle
bearSfp = bearRaw and (na(bearRaw[1]) or not bearRaw[1])
bullSfp = bullRaw and (na(bullRaw[1]) or not bullRaw[1])

plotshape(bearSfp, title = 'Bearish SFP', style = shape.xcross, location = location.abovebar, size = size.tiny, color = color.new(color.red, 0), text = '\nSFP')
plotshape(bullSfp, title = 'Bullish SFP', style = shape.xcross, location = location.belowbar, size = size.tiny, color = color.new(color.lime, 0), text = 'SFP\n')

timezoneEt = 'America/New_York'
nyMinutes = hour(time, timezoneEt) * 60 + minute(time, timezoneEt)
inEodFlattenWindow = nyMinutes >= 15 * 60 and nyMinutes < 16 * 60
// No new opening trades on or after 2:00 PM ET
before2pmEt = nyMinutes < 14 * 60
dayKeyEt = year(time, timezoneEt) * 10000 + month(time, timezoneEt) * 100 + dayofmonth(time, timezoneEt)

var int eodFlattenedDayKey = na

// Entries: reverse on opposite SFP (single `strategy.entry` id, pyramiding = 0). Only during regular session (`session.ismarket`); no new entries at/after 2:00 PM ET
canEnterSfpEt = session.ismarket and before2pmEt and not inEodFlattenWindow
if bullSfp and canEnterSfpEt
    strategy.entry('SFP', strategy.long, comment = 'Bull SFP Trade')
else if bearSfp and canEnterSfpEt
    strategy.entry('SFP', strategy.short, comment = 'Bear SFP Trade')

if inEodFlattenWindow and strategy.position_size != 0
    if na(eodFlattenedDayKey) or eodFlattenedDayKey != dayKeyEt
        strategy.close_all(comment = 'Flatten 3:00 PM ET')
        eodFlattenedDayKey := dayKeyEt
