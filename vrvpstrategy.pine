//@version=5
strategy("VRVP Buy/Sell 3-Bar Strategy", overlay = true, pyramiding = 0, process_orders_on_close = true)

lookbackBars = input.int(2880, "Profile Lookback Bars", minval = 50)
profileRows = input.int(150, "Profile Price Rows", minval = 5, maxval = 200)
thresholdPct = input.float(60.0, "Buy/Sell Threshold %", minval = 50.0, maxval = 100.0, step = 0.1)
holdBars = input.int(3, "Hold Bars", minval = 1)
showBackground = input.bool(true, "Highlight Active Bias")

f_reset_profile(float[] buyProfile, float[] sellProfile, int rows) =>
    if array.size(buyProfile) != rows
        array.clear(buyProfile)
        array.clear(sellProfile)
        for _ = 0 to rows - 1
            array.push(buyProfile, 0.0)
            array.push(sellProfile, 0.0)
    else
        for i = 0 to rows - 1
            array.set(buyProfile, i, 0.0)
            array.set(sellProfile, i, 0.0)

f_profile_sum(float[] profile) =>
    total = 0.0
    for i = 0 to array.size(profile) - 1
        total += array.get(profile, i)
    total

var float[] buyProfile = array.new_float(0)
var float[] sellProfile = array.new_float(0)
var int entryBarIndex = na

barsInProfile = math.min(lookbackBars, bar_index + 1)
rangeHigh = ta.highest(high, barsInProfile)
rangeLow = ta.lowest(low, barsInProfile)
priceRange = rangeHigh - rangeLow
priceStep = priceRange / profileRows

f_reset_profile(buyProfile, sellProfile, profileRows)

if priceStep > 0
    for i = 0 to barsInProfile - 1
        barHigh = high[i]
        barLow = low[i]
        barRange = math.max(barHigh - barLow, syminfo.mintick)
        barVolume = volume[i]
        isBuyBar = close[i] >= open[i]

        startRow = int(math.max(0, math.min(profileRows - 1, math.floor((barLow - rangeLow) / priceStep))))
        endRow = int(math.max(0, math.min(profileRows - 1, math.floor((barHigh - rangeLow) / priceStep))))

        for row = startRow to endRow
            rowLow = rangeLow + row * priceStep
            rowHigh = row == profileRows - 1 ? rangeHigh : rowLow + priceStep
            overlap = math.max(0.0, math.min(barHigh, rowHigh) - math.max(barLow, rowLow))
            allocatedVolume = barVolume * overlap / barRange

            if isBuyBar
                array.set(buyProfile, row, array.get(buyProfile, row) + allocatedVolume)
            else
                array.set(sellProfile, row, array.get(sellProfile, row) + allocatedVolume)

buyVolume = f_profile_sum(buyProfile)
sellVolume = f_profile_sum(sellProfile)
totalVolume = buyVolume + sellVolume

buyPct = totalVolume > 0 ? buyVolume / totalVolume * 100.0 : na
sellPct = totalVolume > 0 ? sellVolume / totalVolume * 100.0 : na

longSignal = not na(buyPct) and buyPct >= thresholdPct
shortSignal = not na(sellPct) and sellPct >= thresholdPct

if strategy.position_size == 0
    if longSignal
        strategy.entry("VRVP Long", strategy.long)
    else if shortSignal
        strategy.entry("VRVP Short", strategy.short)

positionJustOpened = strategy.position_size != 0 and strategy.position_size[1] == 0
positionJustClosed = strategy.position_size == 0 and strategy.position_size[1] != 0

if positionJustOpened
    entryBarIndex := bar_index

if strategy.position_size != 0 and not na(entryBarIndex) and bar_index - entryBarIndex >= holdBars
    strategy.close(strategy.position_size > 0 ? "VRVP Long" : "VRVP Short", comment = str.tostring(holdBars) + "-bar exit")

if positionJustClosed
    entryBarIndex := na

bgcolor(showBackground ? longSignal ? color.new(color.green, 88) : shortSignal ? color.new(color.red, 88) : na : na)

plot(buyPct, "VRVP Buy %", color = color.green, linewidth = 2, display = display.pane)
plot(sellPct, "VRVP Sell %", color = color.red, linewidth = 2, display = display.pane)
hline(thresholdPct, "Threshold", color = color.gray, linestyle = hline.style_dashed)

alertcondition(longSignal, "VRVP Long Signal", "VRVP buy percentage is at or above the threshold.")
alertcondition(shortSignal, "VRVP Short Signal", "VRVP sell percentage is at or above the threshold.")
